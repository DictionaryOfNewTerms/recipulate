# ==============================================================================
# Recipulate - direnv configuration
# ==============================================================================
# Automatically loads project-specific credentials when entering this directory.
# Only Recipulate tokens are available - true credential isolation.
#
# Docs: ~/.claude/docs/credential-security.md
# ==============================================================================

source_env ~/.env.credentials/recipulate.env

# Export for gh CLI (isolated per-project)
# gh CLI respects GITHUB_TOKEN env var for authentication
export GITHUB_TOKEN="${RECIPULATE_GITHUB_TOKEN}"
