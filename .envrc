# ==============================================================================
# Recipulate - direnv configuration
# ==============================================================================
# Loads shared hobby credentials (GitHub + Vercel).
#
# Docs: ~/.claude/docs/guides/credential-security.md
# ==============================================================================

# Shared hobby credentials (GitHub PAT + Vercel token)
source_env ~/.env.credentials/hobby.env
export GITHUB_TOKEN="${HOBBY_GITHUB_TOKEN}"
export VERCEL_TOKEN="${HOBBY_VERCEL_TOKEN}"
