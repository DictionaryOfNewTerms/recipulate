# ==============================================================================
# Recipulate - direnv configuration
# ==============================================================================
# Public open-source project under DictionaryOfNewTerms GitHub org.
# Deployed via GitHub Pages (not Vercel).
#
# Docs: ~/.claude/docs/guides/credential-guide.md
# ==============================================================================

# Org credentials (primary — for pushing to DictionaryOfNewTerms/recipulate)
source_env ~/.env.credentials/org-dictionaryofnewterms.env
export GITHUB_TOKEN="${DICTIONARYOFNEWTERMS_GITHUB_TOKEN}"

# Shared hobby credentials (Vercel token for any remaining cleanup)
source_env ~/.env.credentials/hobby.env
export VERCEL_TOKEN="${HOBBY_VERCEL_TOKEN}"
